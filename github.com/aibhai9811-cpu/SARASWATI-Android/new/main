name: Build SARASWATI APK

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Set up JDK 17
        uses: actions/setup-java@v3
        with:
          java-version: '17'
          distribution: 'temurin'

      - name: Setup Android SDK
        uses: android-actions/setup-android@v2

      - name: Download Gradle Wrapper
        run: |
          curl -sL https://services.gradle.org/distributions/gradle-8.1.1-bin.zip -o gradle.zip
          unzip -q gradle.zip
          curl -sL https://raw.githubusercontent.com/gradle/gradle/v8.1.1/gradlew -o gradlew_new
          chmod +x gradlew

      - name: Make gradlew executable
        run: chmod +x gradlew

      - name: Build Debug APK
        run: ./gradlew assembleDebug --stacktrace

      - name: Upload APK
        uses: actions/upload-artifact@v3
        with:
          name: SARASWATI-APK
          path: app/build/outputs/apk/debug/app-debug.apk
